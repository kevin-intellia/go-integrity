# Get these from https://developers.facebook.com (not Events Manager)
# 1. Create a Business app → add Marketing API product
# 2. Graph API Explorer → generate token with ads_read permission
# 3. Ad account ID from Ads Manager URL: act_XXXXXXXXX

META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=act_1369099874606476

# GoHighLevel → Settings → Private Integrations
# Location ID is in the sub-account URL: /location/XXXXXXXX/settings/...
GHL_PRIVATE_INTEGRATION_TOKEN=your_ghl_token_here
GHL_LOCATION_ID=fXxDgtMxnW842psPbTR8
